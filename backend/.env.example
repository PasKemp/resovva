# Resovva Backend – Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.

# ── Datenbank ────────────────────────────────────────────────────────────────
# Haupt-PostgreSQL-Datenbank (auch für LangGraph-Checkpoints nutzbar)
DATABASE_URL=postgresql://resovva:password@localhost:5432/resovva

# LangGraph-Persistenz (kann dieselbe URL wie DATABASE_URL sein)
# POSTGRES_CHECKPOINT_URL=postgresql://resovva:password@localhost:5432/resovva

# ── Auth & JWT ────────────────────────────────────────────────────────────────
# Zufälliger 256-Bit-Schlüssel (Beispiel: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production-use-a-random-256bit-key
JWT_EXPIRE_DAYS=7

# ── LLM – eine der beiden Optionen reicht ────────────────────────────────────
# DEV: Standard OpenAI (Pay-per-Use, platform.openai.com)
OPENAI_API_KEY=sk-proj-dein-key-von-platform-openai-com...

# Production: Azure OpenAI (DSGVO, Deutschland)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://dein-resource-name.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# OPENAI_API_VERSION=2024-02-15-preview

# ── E-Mail (Passwort-Reset) ──────────────────────────────────────────────────
# Ohne Key: Reset-URL wird nur ins Log geschrieben (DEV-Modus)
# RESEND_API_KEY=re_dein-resend-api-key
# EMAIL_FROM=noreply@resovva.de

# ── Qdrant (Vektor-DB) ───────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=resovva_docs          # Default: resovva_docs

# ── Embeddings ────────────────────────────────────────────────────────────────
# DEV: OpenAI (text-embedding-3-small, automatisch via OPENAI_API_KEY)
# EMBEDDING_MODEL=text-embedding-3-small
# Production: Azure Deployment-Name für das Embedding-Modell (Pflicht wenn Azure aktiv)
# EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── CORS (Frontend-Origin) ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── S3 / MinIO Storage (Epic 2) ──────────────────────────────────────────────
# Lokal via Docker Compose: minioadmin:minioadmin auf Port 9000
# Produktion: AWS S3 oder Azure Blob (endpoint anpassen)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=resovva-docs

# ── PDF-Parsing Backend ──────────────────────────────────────────────────────
# text | unstructured | azure
INGEST_BACKEND=text

# LlamaParse Cloud (Fallback für schlechte Scan-Qualität / Tabellen / Bilder)
# Kostenlos-Kontingent: 1000 Seiten/Tag – https://cloud.llamaindex.ai/
# LLAMA_CLOUD_API_KEY=llx-...
# MIN_CHARS_PER_PAGE=50      # Mindestzeichen/Seite bevor LlamaParse greift (Default: 50)

# Azure Document Intelligence (wenn INGEST_BACKEND=azure)
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=...
# AZURE_DOCUMENT_INTELLIGENCE_KEY=...

# ── Sonstige ──────────────────────────────────────────────────────────────────
# MaStR-API Basis-URL (Marktstammdatenregister, Default reicht für Produktion)
# MASTR_API_BASE_URL=https://api.marktstammdatenregister.de
# DATA_RETENTION_DAYS=30     # Automatische DSGVO-Löschfrist (Default: 30 Tage)
