# ─────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the FastAPI backend (used by the API service client)
# In development the Vite proxy handles /api/* so this is only needed
# when running outside of Vite (e.g. Storybook, tests).
VITE_API_URL=http://localhost:8000

# Stripe public key (used for client-side checkout redirect)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_key_here
